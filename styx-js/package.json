{
  "name": "styx-js",
  "version": "1.0.0",
  "description": "Sovereign P2P cryptographic ledger for the browser — JavaScript port of the Styx Dart library",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./crypto": "./src/crypto/index.js",
    "./ledger": "./src/ledger/index.js",
    "./transport": "./src/transport/index.js",
    "./storage": "./src/storage/index.js"
  },
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "test:unit": "node --experimental-vm-modules node_modules/.bin/jest --forceExit --testPathIgnorePatterns=nostr-relay",
    "test:relay": "docker compose -f docker-compose.test.yml up -d && NOSTR_RELAY=ws://localhost:17777 node --experimental-vm-modules node_modules/.bin/jest test/integration/nostr-relay.test.js --forceExit",
    "test:relay:down": "docker compose -f docker-compose.test.yml down",
    "test:webrtc": "npx playwright test",
    "test:webrtc:manual": "node test/webrtc/manual/server.js",
    "lint": "eslint src/",
    "build": "rollup -c",
    "build:fidesvox": "rollup -c rollup.fidesvox.js"
  },
  "dependencies": {
    "@noble/ciphers": "^1.0.0",
    "@noble/curves": "^1.6.0",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.5.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@playwright/test": "^1.58.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "cookie-parser": "^1.4.7",
    "eslint": "^9.0.0",
    "express": "^5.2.1",
    "fast-check": "^3.22.0",
    "hash-wasm": "4.12.0",
    "jest": "^29.7.0",
    "jsonwebtoken": "^9.0.3",
    "rollup": "^4.0.0",
    "ws": "^8.21.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "keywords": [
    "p2p",
    "cryptography",
    "ledger",
    "e2e-encryption",
    "webrtc",
    "nostr"
  ]
}
