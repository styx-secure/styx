{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/styx-secure/styx/blob/main/docs/governance/schemas/remediation-request-v1.schema.json",
  "title": "Styx remediation request v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "tool_version",
    "review_report_sha256",
    "repository",
    "issue_number",
    "base_sha",
    "head_sha",
    "issue_body_sha256",
    "diff_sha256",
    "remediation_round_id",
    "reviewer_class",
    "reviewer_execution_id",
    "items",
    "generation"
  ],
  "properties": {
    "schema": {
      "const": "styx.remediation-request/v1"
    },
    "tool_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "review_report_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "repository": {
      "type": "string",
      "minLength": 1
    },
    "issue_number": {
      "type": "integer",
      "minimum": 1
    },
    "base_sha": {
      "$ref": "#/$defs/commitSha"
    },
    "head_sha": {
      "$ref": "#/$defs/commitSha"
    },
    "issue_body_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "diff_sha256": {
      "$ref": "#/$defs/sha256",
      "description": "Advisory metadata only, carried over from the review report. Unauthenticated: the authoritative binding of the code state is base_sha + head_sha."
    },
    "remediation_round_id": {
      "type": "integer",
      "minimum": 1
    },
    "reviewer_class": {
      "$ref": "#/$defs/reviewerClass"
    },
    "reviewer_execution_id": {
      "$ref": "#/$defs/canonicalId"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/item"
      }
    },
    "generation": {
      "$ref": "#/$defs/generation"
    }
  },
  "$defs": {
    "commitSha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "canonicalId": {
      "description": "Canonical form of an execution or context identifier: an ASCII alphanumeric first character followed by ASCII alphanumerics and the separators '-', '_', '.', at most 128 characters. Everything else - empty, surrounding or embedded whitespace, control bytes, and all non-ASCII text including Unicode confusables - is rejected rather than normalized.",
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "reviewerClass": {
      "enum": [
        "HUMAN",
        "DELEGATED_AGENT"
      ]
    },
    "severity": {
      "enum": [
        "BLOCKER",
        "HIGH",
        "MEDIUM",
        "LOW",
        "INFO"
      ]
    },
    "lifecycle": {
      "enum": [
        "OPEN",
        "ADDRESSED_PENDING_REVERIFY",
        "RESOLVED",
        "WAIVED_BY_HUMAN"
      ]
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_json",
        "timestamp_omitted"
      ],
      "properties": {
        "canonical_json": {
          "const": "RFC8259-sort-keys-utf8-lf"
        },
        "timestamp_omitted": {
          "const": true
        }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_id",
        "severity",
        "component_path",
        "problem",
        "required_behavior",
        "required_test",
        "acceptance_criterion",
        "lifecycle",
        "review_report_sha256",
        "remediation_round_id"
      ],
      "properties": {
        "finding_id": {
          "$ref": "#/$defs/sha256"
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "component_path": {
          "type": "string",
          "minLength": 1
        },
        "problem": {
          "type": "string",
          "minLength": 1
        },
        "required_behavior": {
          "type": "string",
          "minLength": 1
        },
        "required_test": {
          "type": "string",
          "minLength": 1
        },
        "acceptance_criterion": {
          "type": "string",
          "minLength": 1
        },
        "lifecycle": {
          "$ref": "#/$defs/lifecycle"
        },
        "review_report_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "remediation_round_id": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
